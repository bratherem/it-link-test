{
    "name": "bratherem/it-link-test",
    "description": "REST API service for car advertisements",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-composer": "~2.0.10"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "phpunit/phpunit": "^10.5",
        "yiisoft/yii2-faker": "~2.0.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "app\\tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        },
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
